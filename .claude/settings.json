{
  "permissions": {
    "allow": [
      "Bash(QT_QPA_PLATFORM=offscreen PYTHONPATH=src PYTEST_QT_API=pyqt6 python -m pytest*)",
      "Bash(ruff check *)",
      "Bash(PYTHONPATH=src python -m galvo_gui*)",
      "Bash(pip install -e .*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; case \"$f\" in *.py) ruff check \"$f\";; esac; }"
          }
        ]
      }
    ]
  }
}
